# LLM Provider Configuration
# Default: Ollama (local, no API key needed)
# Run: ollama pull llama2:7b  OR  ollama pull qwen2.5-coder:7b

PROVIDER_ORDER=ollama
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Add your own API keys for better models
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=...

# Cost & Budget Control
BUDGET_USD=2.00
LOG_LEVEL=info

# Research Depth
# "quick" = 2 min search, ~500 words output
# "thorough" = 5 min search, ~1500 words output
RESEARCH_DEPTH=thorough
