# Provider Routing Order (comma-separated, tried in order)
# Options: ollama, opencode, openrouter, gemini, openai, anthropic
PROVIDER_ORDER=ollama

# Local Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# API Keys (only required if added to PROVIDER_ORDER)
# OPENCODE_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Budget Guard (USD)
BUDGET_USD=1.50

# Logging Level
LOG_LEVEL=info
